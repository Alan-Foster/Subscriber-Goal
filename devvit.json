{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "subscriber-goal-",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "app.html",
        "height": "regular"
      },
      "app": {
        "entry": "app.html",
        "height": "regular"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "media": {
    "dir": "assets"
  },
  "settings": {
    "global": {
      "promoSubreddit": {
        "type": "string",
        "label": "Promo Subreddit",
        "defaultValue": "SubGoal"
      }
    }
  },
  "permissions": {
    "media": true,
    "realtime": true,
    "redis": true,
    "reddit": {
      "enable": true,
      "asUser": ["SUBSCRIBE_TO_SUBREDDIT"]
    }
  },
  "menu": {
    "items": [
      {
        "label": "Sub Goal - Create a New Goal",
        "description": "Create a new subscriber goal post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-goal"
      },
      {
        "label": "Sub Goal - Delete This Goal",
        "description": "Delete the current subscriber goal post",
        "location": "post",
        "forUserType": "moderator",
        "postFilter": "currentApp",
        "endpoint": "/internal/menu/delete-goal"
      },
      {
        "label": "Sub Goal - Erase a User's Data",
        "description": "Erase subscriber data for a specific user",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/erase-data"
      }
    ]
  },
  "forms": {
    "createGoalForm": "/internal/form/create-goal",
    "deleteGoalForm": "/internal/form/delete-goal",
    "eraseDataForm": "/internal/form/erase-data"
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onAppUpgrade": "/internal/triggers/on-app-upgrade",
    "onModAction": "/internal/triggers/on-mod-action"
  },
  "scheduler": {
    "tasks": {
      "posts-updater-job": {
        "endpoint": "/internal/scheduler/posts-updater-job",
        "cron": "*/1 * * * *"
      }
    }
  }
}
